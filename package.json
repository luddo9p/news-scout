{
  "name": "agent-scout",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx --env-file=.env src/index.ts --agent=tech-ai",
    "start:luxe": "tsx --env-file=.env src/index.ts --agent=luxe-digital",
    "start:bourse": "tsx --env-file=.env src/index.ts --agent=bourse-scout",
    "start:higgons": "tsx --env-file=.env src/index.ts --agent=higgons-scout",
    "start:maugey": "tsx --env-file=.env src/index.ts --agent=maugey-scout",
    "start:dunand": "tsx --env-file=.env src/index.ts --agent=dunand-scout",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.6.0",
    "resend": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
